{
  "$schema": "https://schemas.zeropress.dev/build-pages-config/v0.1/schema.json",
  "version": "0.1",
  "site": {
    "title": "Docs2 Preview",
    "description": "A sidebar documentation preview for the bundled docs2 theme.",
    "url": "https://docs2.zeropress.page",
    "locale": "en-US",
    "indexing": false,
    "search": true,
    "expose_generator": true,
    "footer": {
      "copyright_text": "ZeroPress Docs2 Preview"
    }
  },
  "menus": {
    "primary": {
      "name": "Primary Menu",
      "items": [
        {
          "title": "GET STARTED",
          "url": "/",
          "meta": { "accent": "blue" },
          "children": [
            { "title": "Overview", "url": "/" },
            { "title": "Getting Started", "url": "/getting-started" }
          ]
        },
        {
          "title": "GUIDES",
          "url": "/guides/markdown",
          "meta": { "accent": "sage" },
          "children": [
            {
              "title": "Markdown",
              "url": "/guides/markdown",
              "children": [
                { "title": "Markdown Examples", "url": "/markdown-examples/" }
              ]
            }
          ]
        },
        {
          "title": "REFERENCE",
          "url": "/guides/configuration",
          "meta": { "accent": "gold" },
          "children": [
            { "title": "Configuration", "url": "/guides/configuration" }
          ]
        }
      ]
    },
    "footer": {
      "name": "Footer Menu",
      "items": [
        { "title": "Privacy Policy", "url": "/legal/privacy" },
        { "title": "Terms of Use", "url": "/legal/terms" }
      ]
    }
  },
  "collections": {
    "get_started": {
      "title": "Get Started",
      "items": [
        "index.md",
        "getting-started.md"
      ]
    },
    "guides": {
      "title": "Guides",
      "items": [
        "guides/markdown.md",
        "markdown-examples/index.md"
      ]
    },
    "reference": {
      "title": "Reference",
      "items": [
        "guides/configuration.md"
      ]
    }
  },
  "markdown": {
    "updated_at": "git"
  },
  "front_page": {
    "type": "markdown",
    "file": "index.md"
  }
}
